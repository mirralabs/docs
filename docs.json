{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mirra",
  "colors": {
    "primary": "#d65a31",
    "light": "#e27d56",
    "dark": "#b34621"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Start here",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/mirrors",
              "concepts/sessions",
              "concepts/scenarios",
              "concepts/fidelity"
            ]
          },
          {
            "group": "CLI",
            "pages": ["cli/installation", "cli/up", "cli/run", "cli/reset"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/first-scenario",
              "guides/vitest-plugin",
              "guides/ci-integration",
              "guides/coding-agents-mcp"
            ]
          },
          {
            "group": "Mirrors",
            "pages": [
              "mirrors/overview",
              "mirrors/stripe",
              "mirrors/resend",
              "mirrors/twilio"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/scenario-format",
              "reference/evaluation-dp",
              "reference/api"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Mirra site",
          "href": "https://mirra.run",
          "icon": "globe"
        },
        {
          "anchor": "Thesis",
          "href": "https://mirra.run/thesis",
          "icon": "book-open-cover"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/mirrahq",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Request access",
        "href": "https://mirra.run/access"
      }
    ],
    "primary": {
      "type": "button",
      "label": "mirra.run",
      "href": "https://mirra.run"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/mirradev",
      "github": "https://github.com/mirrahq"
    }
  }
}
